# Ingutsheni Central | HEM — Environment Template
# Copy this file to .env and fill in real values, or run:  python setup.py
# Never commit the real .env to version control.

# ── Flask ────────────────────────────────────────────────────────
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(48))"
SECRET_KEY=replace-with-a-long-random-string

# ── Server ───────────────────────────────────────────────────────
# 0.0.0.0 makes the app reachable from other machines on the network
HOST=0.0.0.0
PORT=8000
THREADS=4

# ── Storage ──────────────────────────────────────────────────────
# Absolute paths recommended for production
DATABASE_PATH=/opt/hem/biomedical.db
UPLOAD_FOLDER=/opt/hem/uploads

# ── Session ──────────────────────────────────────────────────────
# Auto-logout after this many hours of inactivity
SESSION_HOURS=8
